# Copy this file to qa/configs/devices.env and adjust the values below.

export QA_XCODE_PROJECT="$PROJECT_ROOT/flutter_client_demo/ios/Runner.xcodeproj"
export QA_XCODE_SCHEME="Runner"
export QA_XCODE_ONLY_TESTING="RunnerUITests"

# Use one of the two destinations below.
export QA_SIMULATOR_NAME="iPhone 15"
# export QA_DEVICE_UDID="00008110-001234560E00001E"

export QA_APP_BUNDLE_ID="com.example.flutterClientDemo"
export QA_EXPORT_CONTAINER_BUNDLE_ID="$QA_APP_BUNDLE_ID"
export QA_EXPORT_RELATIVE_PATH="Documents/qa_artifacts"
export QA_FLUTTER_PROJECT_DIR="$PROJECT_ROOT/flutter_client_demo"
export QA_FLUTTER_DRIVER="test_driver/main.dart"
export QA_FLUTTER_IT_TARGET="test_driver/app.dart"
export QA_FLUTTER_TEST_CASES="testSmoke_LoginBrowseProfileLogout testSearchAndCategoryFilters"
export QA_FLUTTER_CASE_RETRIES="2"

export QA_TEST_USERNAME="demo_operator"
export QA_TEST_PASSWORD="123456"

# Optional: override derived data or artifacts root if you want them outside the repo.
# export QA_REPORTS_ROOT="$PROJECT_ROOT/qa/reports"
# export QA_DERIVED_DATA_PATH="$PROJECT_ROOT/.derived_data"

# Real Flutter app wiring can be overridden later if you want the same qa shell around another repo.
